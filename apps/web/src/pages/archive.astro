---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SearchBar from '../components/SearchBar.astro';
import BatchCard from '../components/BatchCard.astro';
import { formatBatchLabel } from '../lib/formatters';
import { articles, summary, journalList, batches, archiveBatchHref, archiveJournalHref } from '../lib/data';

const journals = journalList();
const recentBatches = batches.slice(0, 12);
---
<BaseLayout title="MIXZ Archive" description="All MIXZ literature records">
  <section class="hero small">
    <p class="eyebrow">Archive</p>
    <h1>全部文献</h1>
    <p>{summary.total_articles} 篇文章，来自 {journals.length} 个期刊/来源。支持本页搜索，也支持从首页按 batch 或 journal 跳转筛选。</p>
    <div id="activeFilter" class="filter-state" hidden>
      <span></span>
      <a href="/archive">清除筛选</a>
    </div>
    <SearchBar />
  </section>

  <section class="archive-layout">
    <aside class="panel filters">
      <h2>Journals</h2>
      <ul class="simple-list linked-list">
        {journals.map((item) => (
          <li>
            <a href={archiveJournalHref(item.name)}>
              <span>{item.name}</span>
              <strong>{item.count}</strong>
            </a>
          </li>
        ))}
      </ul>
      <h2>Recent batches</h2>
      <div class="batch-list-sidebar">
        {recentBatches.map((batch) => (
          <BatchCard batch={batch} variant="compact" />
        ))}
      </div>
    </aside>
    <div id="archiveList" class="article-list">
      {articles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  <script>
    const params = new URLSearchParams(window.location.search);
    const journalFilter = params.get('journal');
    const batchFilter = params.get('batch');
    const input = document.querySelector('#archiveSearch');
    const cards = [...document.querySelectorAll('.article-card')];
    const activeFilter = document.querySelector('#activeFilter');
    const activeFilterText = activeFilter?.querySelector('span');

    if (activeFilter instanceof HTMLElement && activeFilterText) {
      const labels = [];
      if (journalFilter) labels.push(`Journal: ${journalFilter}`);
      if (batchFilter) labels.push(`Batch: ${batchFilter}`);
      if (labels.length > 0) {
        activeFilterText.textContent = `当前筛选 · ${labels.join(' · ')}`;
        activeFilter.hidden = false;
      }
    }

    const matchesFilters = (card: Element) => {
      const journal = card.getAttribute('data-journal') || '';
      const batches = (card.getAttribute('data-batches') || '').split('|');
      if (journalFilter && journal !== journalFilter) return false;
      if (batchFilter && !batches.includes(batchFilter)) return false;
      return true;
    };

    const applyFilters = () => {
      const q = (input instanceof HTMLInputElement ? input.value : '').trim().toLowerCase();
      for (const card of cards) {
        const text = (card.getAttribute('data-search') || card.textContent || '').toLowerCase();
        const matchesSearch = q.length === 0 || text.includes(q);
        card.toggleAttribute('hidden', !matchesFilters(card) || !matchesSearch);
      }
    };

    input?.addEventListener('input', applyFilters);
    applyFilters();
  </script>
</BaseLayout>
