---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SearchBar from '../components/SearchBar.astro';
import { formatBatchLabel, formatBatchShort, getRelativeTime } from '../lib/formatters.ts';
import { articles, summary, journalList, batches, archiveBatchHref, archiveJournalHref } from '../lib/data';

const journals = journalList();
const recentBatches = batches.slice(0, 12);
const latestBatch = recentBatches[0];
---
<BaseLayout title="MIXZ Archive" description="All MIXZ literature records">
  <section class="hero small archive-hero">
    <p class="eyebrow">Archive</p>
    <h1>全部文献</h1>
    <p>{summary.total_articles} 篇文章，来自 {journals.length} 个期刊/来源。支持本页搜索，也支持从首页按 batch 或 journal 跳转筛选。</p>
    <div id="activeFilter" class="filter-state" hidden>
      <span></span>
      <a href="/archive">清除筛选</a>
    </div>
    <SearchBar />
  </section>

  <section class="archive-layout">
    <aside class="archive-sidebar" aria-label="Archive filters">
      <div class="panel archive-panel archive-panel--journals">
        <div class="archive-panel__heading">
          <h2>Journals</h2>
          <span>{journals.length}</span>
        </div>
        <ul class="simple-list linked-list archive-filter-list">
          {journals.map((item) => (
            <li>
              <a href={archiveJournalHref(item.name)}>
                <span>{item.name}</span>
                <strong>{item.count}</strong>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="panel archive-panel archive-panel--batches">
        <div class="archive-panel__heading">
          <div>
            <h2>Recent batches</h2>
            <p>选择一个批次筛选右侧文献</p>
          </div>
          {latestBatch && <a href={archiveBatchHref(latestBatch.batch_id)}>筛选最新</a>}
        </div>
        <div class="archive-batch-actions" aria-label="Recent batch filters">
          {recentBatches.map((batch) => (
            <div class="archive-batch-action">
              <a class="archive-batch-filter" href={archiveBatchHref(batch.batch_id)}>
                <span class="archive-batch-filter__main">
                  <strong>{formatBatchLabel(batch.batch_id)}</strong>
                  <span>{getRelativeTime(batch.crawl_time || batch.crawl_date)}</span>
                </span>
                <span class="archive-batch-filter__count">{batch.article_count ?? batch.articles?.length ?? 0}</span>
              </a>
              <a class="archive-batch-detail" href={`/batches/${batch.batch_id}.html`}>
                详情 · {formatBatchShort(batch.batch_id)}
              </a>
            </div>
          ))}
        </div>
      </div>
    </aside>

    <section class="panel archive-panel archive-results" aria-labelledby="archiveResultsTitle">
      <div class="archive-panel__heading archive-results__heading">
        <div>
          <p class="eyebrow">Results</p>
          <h2 id="archiveResultsTitle">文献列表</h2>
        </div>
        <span id="archiveCount">{articles.length} 篇</span>
      </div>
      <div id="archiveList" class="article-list archive-article-list">
        {articles.map((article) => <ArticleCard article={article} />)}
      </div>
    </section>
  </section>

  <script>
    const params = new URLSearchParams(window.location.search);
    const journalFilter = params.get('journal');
    const normalizeBatchId = (value: string | null) => (value || '').trim().replaceAll('_', ' ').replace(/\s+/g, ' ');
    const batchFilter = normalizeBatchId(params.get('batch'));
    const input = document.querySelector('#archiveSearch');
    const cards = [...document.querySelectorAll('.article-card')];
    const activeFilter = document.querySelector('#activeFilter');
    const activeFilterText = activeFilter?.querySelector('span');
    const archiveCount = document.querySelector('#archiveCount');

    if (activeFilter instanceof HTMLElement && activeFilterText) {
      const labels = [];
      if (journalFilter) labels.push(`Journal: ${journalFilter}`);
      if (batchFilter) labels.push(`Batch: ${batchFilter}`);
      if (labels.length > 0) {
        activeFilterText.textContent = `当前筛选 · ${labels.join(' · ')}`;
        activeFilter.hidden = false;
      }
    }

    const matchesFilters = (card: Element) => {
      const journal = card.getAttribute('data-journal') || '';
      const batches = (card.getAttribute('data-batches') || '').split('|').map((value) => normalizeBatchId(value));
      if (journalFilter && journal !== journalFilter) return false;
      if (batchFilter && !batches.includes(batchFilter)) return false;
      return true;
    };

    const applyFilters = () => {
      const q = (input instanceof HTMLInputElement ? input.value : '').trim().toLowerCase();
      for (const card of cards) {
        const text = (card.getAttribute('data-search') || card.textContent || '').toLowerCase();
        const matchesSearch = q.length === 0 || text.includes(q);
        card.toggleAttribute('hidden', !matchesFilters(card) || !matchesSearch);
      }
      const visibleCount = cards.filter((card) => !card.hasAttribute('hidden')).length;
      if (archiveCount) archiveCount.textContent = `${visibleCount} 篇`;
    };

    input?.addEventListener('input', applyFilters);
    applyFilters();
  </script>
</BaseLayout>
