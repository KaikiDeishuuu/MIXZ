---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-main">
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="footer-logo__icon">🔬</span>
          <span class="footer-logo__text">MIXZ</span>
        </div>
        <p class="footer-tagline">Biomedical Imaging Literature Monitor</p>
        <p class="footer-description">
          自动追踪生物医学成像领域的最新文献，每日更新。
        </p>
      </div>
      
      <div class="footer-section">
        <h3 class="footer-section__title">导航</h3>
        <ul class="footer-links">
          <li><a href="/">最新批次</a></li>
          <li><a href="/archive">文献归档</a></li>
          <li><a href="/protocols">实验方案</a></li>
          <li><a href="/api/stats">API 文档</a></li>
        </ul>
      </div>
      
      <div class="footer-section">
        <h3 class="footer-section__title">更新范围</h3>
        <ul class="footer-tech">
          <li><span class="tech-badge">Microscopy</span></li>
          <li><span class="tech-badge">Bioimaging</span></li>
          <li><span class="tech-badge">Protocols</span></li>
          <li><span class="tech-badge">Daily</span></li>
        </ul>
        <p class="footer-note">
          关注生物医学成像领域的新增与重复命中文献。
        </p>
      </div>
      
      <div class="footer-section">
        <h3 class="footer-section__title">关于</h3>
        <p class="footer-about">
          MIXZ 是一个开源的文献监控工具，源码与反馈入口托管在 GitHub。
        </p>
        <div class="footer-social">
          <a href="https://github.com/KaikiDeishuuu/MIXZ" aria-label="GitHub repository" class="social-link">
            <span>💻</span>
          </a>
          <a href="https://github.com/KaikiDeishuuu/MIXZ/issues" aria-label="GitHub issues" class="social-link">
            <span>↗</span>
          </a>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <div class="footer-bottom__content">
        <span class="footer-copyright">&copy; {year} MIXZ · KaikiDeishuuu</span>
        <span class="footer-status">
          <span class="status-indicator"></span>
          <span>系统运行正常</span>
        </span>
      </div>
    </div>
  </div>
</footer>
