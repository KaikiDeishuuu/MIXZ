---
import { extractHeadings } from '../lib/heading-anchors';

interface Props {
  markdown: string;
}

const { markdown } = Astro.props;
const headings = extractHeadings(markdown);
---

{headings.length > 0 && (
  <aside class="toc" aria-label="Table of contents">
    <div class="toc-header">
      <div class="toc-header__main">
        <span class="toc-icon">📑</span>
        <h2 class="toc-title">目录</h2>
      </div>
      <span class="toc-count">{headings.length}</span>
    </div>
    <div class="toc-progress" aria-hidden="true">
      <span class="toc-progress__bar" data-toc-progress></span>
    </div>
    <nav class="toc-nav">
      <ul class="toc-list">
        {headings.map((heading) => (
          <li class:list={['toc-item', `toc-item--level-${heading.level}`]}>
            <a href={`#${heading.id}`} class="toc-link">
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toc = document.querySelector('.toc');
    const tocNav = document.querySelector('.toc-nav');
    const tocProgress = document.querySelector('[data-toc-progress]');
    const tocLinks = [...document.querySelectorAll('.toc-link')];
    const sections = Array.from(tocLinks).map(link => {
      const id = link.getAttribute('href')?.slice(1);
      return id ? document.getElementById(id) : null;
    }).filter(Boolean);
    let activeLink = null;

    function updateActiveToc() {
      const scrollPos = window.scrollY + 140;
      
      let activeIndex = 0;
      for (let i = 0; i < sections.length; i++) {
        const section = sections[i];
        if (section && section.offsetTop <= scrollPos) {
          activeIndex = i;
        }
      }
      
      tocLinks.forEach((link, i) => link.classList.toggle('active', i === activeIndex));

      const nextActiveLink = tocLinks[activeIndex];
      if (nextActiveLink && nextActiveLink !== activeLink) {
        activeLink = nextActiveLink;
        nextActiveLink.scrollIntoView({ block: 'nearest', inline: 'nearest' });
      }

      if (tocProgress instanceof HTMLElement) {
        const documentHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = documentHeight > 0 ? Math.min(1, Math.max(0, window.scrollY / documentHeight)) : 0;
        tocProgress.style.transform = `scaleX(${progress})`;
      }
    }

    tocLinks.forEach((link) => {
      link.addEventListener('click', () => {
        toc?.classList.add('toc--navigating');
        window.setTimeout(() => toc?.classList.remove('toc--navigating'), 650);
      });
    });
    
    window.addEventListener('scroll', updateActiveToc, { passive: true });
    tocNav?.addEventListener('scroll', updateActiveToc, { passive: true });
    updateActiveToc();
  });
</script>
