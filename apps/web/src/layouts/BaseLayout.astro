---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  buildInfo?: string;
}

const {
  title = 'MIXZ Literature',
  description = 'Biomedical imaging literature monitor',
  currentPath = Astro.url.pathname,
  buildInfo
} = Astro.props;

const fullTitle = title === 'MIXZ Literature' ? title : `${title} · MIXZ`;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="stylesheet" href="/styles/global.css?v=20260503-2" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📖</text></svg>" />
  </head>
  <body>
    <Header currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer buildInfo={buildInfo} />
  </body>
</html>
