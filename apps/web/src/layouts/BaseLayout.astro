---
interface Props { title?: string; description?: string; }
const { title = 'MIXZ Literature', description = 'Biomedical imaging literature monitor' } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">MIXZ</a>
      <nav aria-label="Primary navigation">
        <a href="/">Latest</a>
        <a href="/archive">Archive</a>
        <a href="/protocols">Protocols</a>
        <a href="/api/stats">API</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>SQLite truth → JSON contract → Astro static site.</span>
      <span>静态页面不依赖 API 存活。</span>
    </footer>
  </body>
</html>
