---
import { formatBatchLabel, formatBatchShort, getRelativeTime } from '../lib/formatters';
import type { BatchPayload } from '../types';

interface Props {
  batch: BatchPayload;
  variant?: 'compact' | 'full';
}

const { batch, variant = 'compact' } = Astro.props;
const articleCount = batch.article_count ?? batch.articles?.length ?? 0;
const newCount = batch.new_articles_count ?? batch.new_articles?.length ?? 0;
const seenCount = batch.seen_again_count ?? (batch.seen_again_articles?.length ?? 0);
const href = `/batches/${batch.batch_id}.html`;

const batchLabel = formatBatchLabel(batch.batch_id);
const batchShort = formatBatchShort(batch.batch_id);
const relativeTime = getRelativeTime(batch.crawl_time || batch.crawl_date || '');
---

<article class:list={['batch-card', `batch-card--${variant}`]}>
  <a href={href} class="batch-card__link">
    <div class="batch-card__header">
      <div class="batch-card__title">
        <span class="batch-card__icon">📦</span>
        <div>
          <h3 class="batch-card__label">{batchLabel}</h3>
          <span class="batch-card__time">{relativeTime}</span>
        </div>
      </div>
      {variant === 'compact' && (
        <span class="batch-card__count">{articleCount}</span>
      )}
    </div>
    
    {variant === 'full' && (
      <div class="batch-card__stats">
        <div class="batch-stat">
          <span class="batch-stat__icon">📄</span>
          <div>
            <strong>{articleCount}</strong>
            <span>总计</span>
          </div>
        </div>
        <div class="batch-stat batch-stat--new">
          <span class="batch-stat__icon">✨</span>
          <div>
            <strong>{newCount}</strong>
            <span>新发现</span>
          </div>
        </div>
        <div class="batch-stat batch-stat--seen">
          <span class="batch-stat__icon">🔄</span>
          <div>
            <strong>{seenCount}</strong>
            <span>重复</span>
          </div>
        </div>
      </div>
    )}
    
    {variant === 'full' && batch.journals && batch.journals.length > 0 && (
      <div class="batch-card__journals">
        {batch.journals.slice(0, 5).map((j: string) => (
          <span class="journal-tag">{j}</span>
        ))}
        {batch.journals.length > 5 && (
          <span class="journal-tag journal-tag--more">+{batch.journals.length - 5}</span>
        )}
      </div>
    )}
    
    <div class="batch-card__meta">
      <span class="batch-card__id">{batchShort}</span>
      <span class="batch-card__arrow">→</span>
    </div>
  </a>
</article>
