---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { marked } from 'marked';
import { protocols } from '../../lib/protocols';

export function getStaticPaths() {
  return protocols.map((protocol) => ({ params: { slug: protocol.slug }, props: { protocol } }));
}

const { protocol } = Astro.props;

// Simple marked configuration - just parse the markdown
const protocolHtml = marked.parse(protocol.markdown, { async: false });
---

<BaseLayout title={`${protocol.title} · MIXZ`} description={protocol.description}>
  <div class="protocol-layout">
    <TableOfContents markdown={protocol.markdown} />
    
    <div class="protocol-content">
      <section class="hero small">
        <p class="eyebrow">{protocol.eyebrow}</p>
        <h1>
          <span class="protocol-icon">{protocol.icon}</span>
          {protocol.title}
        </h1>
        <p class="protocol-description">{protocol.description}</p>
        <div class="tags">
          {protocol.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </section>
      
      <section class="panel prose protocol-doc" set:html={protocolHtml} />
    </div>
  </div>
</BaseLayout>
